{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Character Library Fact v1",
  "type": "object",
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "meta": { "type": "object" }
  },
  "required": ["id", "name", "summary", "tags"],
  "additionalProperties": true
}
